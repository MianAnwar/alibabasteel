# AliBabaSteel environment variables
# Copy to .env.local and fill in production values

# Database
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-in-production-use-a-strong-random-secret"

# Admin credentials (change before going live)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH=""  # bcrypt hash — set via setup script

# Upload limits
MAX_UPLOAD_SIZE_MB=5
